# Copy to .env and adjust as needed for local (non-Docker) development.
# All settings are optional — sensible defaults are used if omitted (see app/config.py).
# docker-compose.yml sets its own values directly and does not read this file.

# APPROVAL_APP_NAME=approval-service
# APPROVAL_ENV=local

# Defaults to a local SQLite file. Point at Postgres instead if you're running one
# locally outside of docker-compose, e.g.:
# APPROVAL_DATABASE_URL=postgresql+asyncpg://approval:approval@localhost:5432/approval_service
# APPROVAL_DATABASE_URL=sqlite+aiosqlite:///./approval_service.db

# APPROVAL_LOG_LEVEL=INFO
